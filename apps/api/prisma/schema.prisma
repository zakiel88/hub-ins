model InventoryItem {
  id                     String    @id @default(uuid()) @db.Uuid
  variantId              String    @map("variant_id") @db.Uuid
  warehouseId            String    @map("warehouse_id") @db.Uuid
  quantityOnHand         Int       @default(0) @map("quantity_on_hand")
  quantityReserved       Int       @default(0) @map("quantity_reserved")
  /// quantity_available is computed in app layer: on_hand - reserved
  lastSyncSourceStoreId  String?   @map("last_sync_source_store_id") @db.Uuid
  lastSyncedAt           DateTime? @map("last_synced_at") @db.Timestamptz()
  syncStatus             String    @default("synced") @map("sync_status") @db.VarChar(20)
  lastCountedAt          DateTime? @map("last_counted_at") @db.Timestamptz()
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  variant      ProductVariant @relation(fields: [variantId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  sourceStore  ShopifyStore? @relation(fields: [lastSyncSourceStoreId], references: [id])

  @@unique([variantId, warehouseId], name: "uq_inv_variant_warehouse")
  @@index([variantId], name: "idx_inv_variant")
  @@index([warehouseId], name: "idx_inv_warehouse")
  @@index([syncStatus], name: "idx_inv_sync_status")
  @@map("inventory_items")
}

