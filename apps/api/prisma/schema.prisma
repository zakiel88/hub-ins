  errors        Json?    @default("[]")
  productId     String?  @map("product_id") @db.Uuid
  variantId     String?  @map("variant_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([importBatchId], name: "idx_ir_batch")
  @@map("import_rows")
}

model SyncLog {
  id             String    @id @default(uuid()) @db.Uuid
  shopifyStoreId String    @map("shopify_store_id") @db.Uuid
  entityType     String    @map("entity_type") @db.VarChar(50)
  syncType       String    @map("sync_type") @db.VarChar(20)
  status         String    @default("running") @db.VarChar(20)
  totalRecords   Int?      @map("total_records")
  syncedRecords  Int?      @map("synced_records")
  errorMessage   String?   @map("error_message")
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  completedAt    DateTime? @map("completed_at") @db.Timestamptz()

  shopifyStore ShopifyStore @relation(fields: [shopifyStoreId], references: [id])

  @@index([shopifyStoreId], name: "idx_sl_store")
  @@index([status], name: "idx_sl_status")
  @@map("sync_logs")
}

model WebhookEvent {
  id                String    @id @default(uuid()) @db.Uuid
  shopifyStoreId    String    @map("shopify_store_id") @db.Uuid
  shopifyWebhookId  String    @map("shopify_webhook_id") @db.VarChar(100)
  topic             String    @db.VarChar(100)
  shopifyEntityId   BigInt?   @map("shopify_entity_id")
  status            String    @default("received") @db.VarChar(20)
  attempts          Int       @default(0)
  payloadHash       String?   @map("payload_hash") @db.VarChar(64)
  rawPayload        Json?     @map("raw_payload")
  errorMessage      String?   @map("error_message")
  receivedAt        DateTime  @default(now()) @map("received_at") @db.Timestamptz()
  processedAt       DateTime? @map("processed_at") @db.Timestamptz()

  shopifyStore ShopifyStore @relation(fields: [shopifyStoreId], references: [id])

  @@unique([shopifyStoreId, shopifyWebhookId], name: "uq_we_store_webhook")
  @@index([shopifyStoreId, topic], name: "idx_we_store_topic")
  @@index([status], name: "idx_we_status")
  @@map("webhook_events")
}

model OrderLog {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  source          String   @db.VarChar(20)   // webhook, manual, sync
  shopifyTopic    String?  @map("shopify_topic") @db.VarChar(50)
  changedFields   Json     @map("changed_fields")
  rawPayload      Json?    @map("raw_payload")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId], name: "idx_ol_order")
  @@index([createdAt], name: "idx_ol_created")
  @@map("order_logs")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  changes    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User? @relation(fields: [userId], references: [id])

  @@index([userId], name: "idx_al_user")
  @@index([entityType, entityId], name: "idx_al_entity")
  @@index([createdAt], name: "idx_al_created")
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@index([token], name: "idx_prt_token")
  @@index([userId], name: "idx_prt_user")
  @@map("password_reset_tokens")
}

// ═══════════════════════════════════════
// Sprint 2 — Metafields Library + Approval
// ═══════════════════════════════════════

model MetafieldDefinition {
  id              String   @id @default(uuid()) @db.Uuid
  namespace       String   @default("custom") @db.VarChar(100)
  key             String   @db.VarChar(100)
  type            String   @db.VarChar(50) // single_line_text_field, number_integer, json, etc.
  ownerType       String   @map("owner_type") @db.VarChar(20) // PRODUCT | VARIANT
  label           String?  @db.VarChar(255)
  description     String?
  validationJson  Json?    @map("validation_json")
  isActive        Boolean  @default(true) @map("is_active")
  isRequired      Boolean  @default(false) @map("is_required")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  catalogSchemas  CatalogMetafieldSchema[]
  values          MetafieldValue[]
  options         MetafieldDefinitionOption[]

  @@unique([namespace, key, ownerType], name: "uq_mfdef_ns_key_owner")
  @@map("metafield_definitions")
}

// ═══════════════════════════════════════
// Metafield Options Library
// ═══════════════════════════════════════

model MetafieldDefinitionOption {
  id           String   @id @default(uuid()) @db.Uuid
  definitionId String   @map("definition_id") @db.Uuid
  value        String   @db.VarChar(500)
  label        String?  @db.VarChar(255) // Display label if different from value
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  definition MetafieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([definitionId, value], name: "uq_mfopt_def_value")
  @@index([definitionId], name: "idx_mfopt_definition")
  @@map("metafield_definition_options")
}

model CatalogMetafieldSchema {
  id                  String   @id @default(uuid()) @db.Uuid
  shopifyCategoryId   String   @map("shopify_category_id") @db.VarChar(100)
  definitionId        String   @map("definition_id") @db.Uuid
  isRequired          Boolean  @default(false) @map("is_required")
  displayOrder        Int      @default(0) @map("display_order")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  definition MetafieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([shopifyCategoryId, definitionId], name: "uq_cms_cat_def")
  @@index([shopifyCategoryId], name: "idx_cms_category")
  @@map("catalog_metafield_schema")
}

model MetafieldValue {
  id               String    @id @default(uuid()) @db.Uuid
  ownerType        String    @map("owner_type") @db.VarChar(20) // PRODUCT | VARIANT
  ownerId          String    @map("owner_id") @db.Uuid
  definitionId     String    @map("definition_id") @db.Uuid
  storeId          String?   @map("store_id") @db.Uuid // NULL = global, non-null = store-specific
  valueJson        Json      @map("value_json")
  status           String    @default("DRAFT") @db.VarChar(20) // DRAFT | PENDING_REVIEW | APPROVED | REJECTED
  submittedBy      String?   @map("submitted_by") @db.Uuid
  reviewerId       String?   @map("reviewer_id") @db.Uuid
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz()
  rejectionReason  String?   @map("rejection_reason")
  // HARDENING: idempotent push tracking
  lastPushedAt     DateTime? @map("last_pushed_at") @db.Timestamptz()
  lastPushedHash   String?   @map("last_pushed_hash") @db.VarChar(64)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  definition MetafieldDefinition @relation(fields: [definitionId], references: [id])
  store      ShopifyStore?       @relation("MetafieldValueStore", fields: [storeId], references: [id])
  submitter  User?               @relation("MetafieldSubmitter", fields: [submittedBy], references: [id])
  reviewer   User?               @relation("MetafieldReviewer", fields: [reviewerId], references: [id])

  // Partial unique indexes handled via raw SQL after prisma db push
  @@index([ownerType, ownerId], name: "idx_mfv_owner")
  @@index([definitionId], name: "idx_mfv_definition")
  @@index([storeId], name: "idx_mfv_store")
  @@index([status], name: "idx_mfv_status")
  @@map("metafield_values")
}

// ═══════════════════════════════════════
// Sprint 2.1 — Product Validation State
// ═══════════════════════════════════════

model ProductValidationState {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  storeId         String?  @map("store_id") @db.Uuid   // NULL = global validation
  isValid         Boolean  @default(false) @map("is_valid")
  missingRequired Json     @default("[]") @map("missing_required") // [{ns,key,label,ownerType}]
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   ShopifyStore? @relation("ValidationStore", fields: [storeId], references: [id])

  @@unique([productId, storeId], name: "uq_pvs_product_store")
  @@index([productId], name: "idx_pvs_product")
  @@index([isValid], name: "idx_pvs_valid")
  @@map("product_validation_states")
}
