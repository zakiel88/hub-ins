// ──────────────────────────────────────
// INS Commerce Hub — Prisma Schema
// Matches architecture v1.1-hardened + patch v1.1.1
// ──────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// Phase A — Independent tables
// ═══════════════════════════════════════

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(255)
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  inventoryItems        InventoryItem[]
  inventoryReservations InventoryReservation[]

  @@map("warehouses")
}

model ShopifyStore {
  id                 String    @id @default(uuid()) @db.Uuid
  storeName          String    @map("store_name") @db.VarChar(255)
  shopifyDomain      String    @unique @map("shopify_domain") @db.VarChar(255)
  market             String?   @db.VarChar(20)
  accessTokenEnc     String    @map("access_token_enc")
  tokenIv            String    @map("token_iv")
  clientIdEnc        String?   @map("client_id_enc")
  clientIdIv         String?   @map("client_id_iv")
  clientSecretEnc    String?   @map("client_secret_enc")
  clientSecretIv     String?   @map("client_secret_iv")
  scopes             String?
  tokenLastRotatedAt DateTime? @map("token_last_rotated_at") @db.Timestamptz()
  apiVersion         String    @default("2025-01") @map("api_version") @db.VarChar(20)
  isActive           Boolean   @default(true) @map("is_active")
  initialSyncDone    Boolean   @default(false) @map("initial_sync_done")
  lastSyncAt         DateTime? @map("last_sync_at") @db.Timestamptz()
  webhookSecret      String?   @map("webhook_secret")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  orders                 Order[]
  inventoryItems         InventoryItem[]
  syncLogs               SyncLog[]
  webhookEvents          WebhookEvent[]
  userAccess             UserStoreAccess[]
  shopifyProductMaps     ShopifyProductMap[]
  shopifyVariantMaps     ShopifyVariantMap[]
  syncJobs               SyncJob[]
  productSyncJobs        ProductSyncJob[] @relation("ProductSyncStore")
  metafieldValues        MetafieldValue[] @relation("MetafieldValueStore")
  validationStates       ProductValidationState[] @relation("ValidationStore")

  @@map("shopify_stores")
}

// ═══════════════════════════════════════
// Phase B — Circular pair: users ↔ brands
// Both FKs nullable → Prisma resolves ordering
// ═══════════════════════════════════════

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  fullName     String   @map("full_name") @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  role         String   @db.VarChar(50)
  brandId      String?  @map("brand_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations — circular with Brand
  brand        Brand?   @relation("UserBrand", fields: [brandId], references: [id])
  ownedBrands  Brand[]  @relation("BrandOwner")

  // Other relations
  importBatches        ImportBatch[]
  auditLogs            AuditLog[]
  passwordResetTokens  PasswordResetToken[]
  tasksAssigned        Task[]          @relation("TaskAssignee")
  taskComments         TaskComment[]
  purchaseOrders       PurchaseOrder[] @relation("POCreator")

  storeAccess          UserStoreAccess[]
  metafieldValuesSubmitted MetafieldValue[] @relation("MetafieldSubmitter")
  metafieldValuesReviewed  MetafieldValue[] @relation("MetafieldReviewer")

  @@index([role], name: "idx_users_role")
  @@index([brandId], name: "idx_users_brand")
  @@map("users")
}

model UserStoreAccess {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  shopifyStoreId String   @map("shopify_store_id") @db.Uuid
  accessLevel    String   @default("viewer") @map("access_level") @db.VarChar(20)  // viewer, editor, admin
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user  User        @relation(fields: [userId], references: [id])
  store ShopifyStore @relation(fields: [shopifyStoreId], references: [id])

  @@unique([userId, shopifyStoreId])
  @@index([userId], name: "idx_usa_user")
  @@index([shopifyStoreId], name: "idx_usa_store")
  @@map("user_store_access")
}

model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  code        String    @unique @db.VarChar(50)
  logoUrl     String?   @map("logo_url")
  ownerUserId String?   @map("owner_user_id") @db.Uuid
  status      String    @default("active") @db.VarChar(20)
  website     String?
  notes       String?

  // Company info
  companyName       String?   @map("company_name") @db.VarChar(255)
  taxCode           String?   @map("tax_code") @db.VarChar(30)
  companyAddress    String?   @map("company_address")

  // ── Brand Info fields (synced from Lark) ──
  warehouseAddress    String?   @map("warehouse_address")
  logoHdUrl           String?   @map("logo_hd_url")
  baseIn              String?   @map("base_in") @db.VarChar(10)
  returnRate          String?   @map("return_rate") @db.VarChar(10)
  contractUrl         String?   @map("contract_url")
  brandDocsUrl        String?   @map("brand_docs_url")

  // Payment Info
  bankAccount         String?   @map("bank_account") @db.VarChar(50)
  bankAccountHolder   String?   @map("bank_account_holder")
  bankName            String?   @map("bank_name") @db.VarChar(100)
  paymentTerms        String?   @map("payment_terms") @db.VarChar(50)
  bankAccountOld      String?   @map("bank_account_old") @db.VarChar(50)
  saleRate            String?   @map("sale_rate") @db.VarChar(50)

  // Pricing & Discount Tiers
  priceListType       String?   @map("price_list_type") @db.VarChar(20)
  discountFormula     String?   @map("discount_formula") @db.VarChar(50)
  revenueTier1        String?   @map("revenue_tier_1") @db.VarChar(30)
  discountTier1       String?   @map("discount_tier_1") @db.VarChar(20)
  revenueTier2        String?   @map("revenue_tier_2") @db.VarChar(30)
  discountTier2       String?   @map("discount_tier_2") @db.VarChar(20)
  revenueTier3        String?   @map("revenue_tier_3") @db.VarChar(30)
  discountTier3       String?   @map("discount_tier_3") @db.VarChar(20)

  // Revenue tier numeric ranges (for calculations)
  revenueTier1From    Float?    @map("revenue_tier_1_from")
  revenueTier1To      Float?    @map("revenue_tier_1_to")
  revenueTier2From    Float?    @map("revenue_tier_2_from")
  revenueTier2To      Float?    @map("revenue_tier_2_to")
  revenueTier3From    Float?    @map("revenue_tier_3_from")
  revenueTier3To      Float?    @map("revenue_tier_3_to")

  // Reconciliation & Debt
  domesticShipping    String?   @map("domestic_shipping") @db.VarChar(50)
  debtNotes           String?   @map("debt_notes")
  paymentSchedule1    String?   @map("payment_schedule_1")
  paymentSchedule2    String?   @map("payment_schedule_2")
  reconciliationMethod String?  @map("reconciliation_method")
  latePaymentPenalty  String?   @map("late_payment_penalty")
  latePaymentNotice   String?   @map("late_payment_notice")

  // Lark sync metadata
  larkRecordId        String?   @unique @map("lark_record_id") @db.VarChar(100)

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations — circular with User
  owner       User?     @relation("BrandOwner", fields: [ownerUserId], references: [id])
  users       User[]    @relation("UserBrand")

  // Other relations
  collections          Collection[]
  contracts            Contract[]
  brandContacts        BrandContact[]
  importBatches        ImportBatch[]
  orderLineItems       OrderLineItem[]
  procurementRequests  ProcurementRequest[]
  purchaseOrders       PurchaseOrder[]
  products             Product[]    @relation("ProductBrand")
  productSyncJobs      ProductSyncJob[] @relation("IntakeBrand")

  @@index([status], name: "idx_brands_status")
  @@index([ownerUserId], name: "idx_brands_owner")
  @@map("brands")
}

model Bank {
  id          String   @id @default(uuid()) @db.Uuid
  fullName    String   @map("full_name") @db.VarChar(255)
  brandName   String   @unique @map("brand_name") @db.VarChar(100)
  swiftCode   String?  @map("swift_code") @db.VarChar(20)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("banks")
}

// ═══════════════════════════════════════
// Phase C — Brand children
// ═══════════════════════════════════════

model Contract {
  id          String    @id @default(uuid()) @db.Uuid
  brandId     String    @map("brand_id") @db.Uuid
  type        String    @db.VarChar(50)
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  terms       String?
  fileUrl     String?   @map("file_url")
  status      String    @default("draft") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  brand Brand @relation(fields: [brandId], references: [id])

  @@index([brandId], name: "idx_contracts_brand")
  @@map("contracts")
}

model BrandContact {
  id        String   @id @default(uuid()) @db.Uuid
  brandId   String   @map("brand_id") @db.Uuid
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  role      String?  @db.VarChar(100)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  brand Brand @relation(fields: [brandId], references: [id])

  @@index([brandId], name: "idx_bc_brand")
  @@map("brand_contacts")
}

model Collection {
  id        String   @id @default(uuid()) @db.Uuid
  brandId   String   @map("brand_id") @db.Uuid
  name      String   @db.VarChar(255)
  season    String?  @db.VarChar(50)
  year      Int?
  status    String   @default("active") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  brand    Brand     @relation(fields: [brandId], references: [id])
  products Product[]

  @@index([brandId], name: "idx_collections_brand")
  @@map("collections")
}

// ═══════════════════════════════════════
// Products Management v3.1
// ═══════════════════════════════════════

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum VariantStatus {
  ACTIVE
  DRAFT
  DISCONTINUED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum SyncAction {
  CREATED
  UPDATED
  SKIPPED
  FAILED
}

enum IssueSeverity {
  ERROR
  WARNING
  INFO
}

enum IssueStatus {
  OPEN
  RESOLVED
  IGNORED
}

// ─── Product (source-agnostic master) ──────────

model Product {
  id              String        @id @default(uuid()) @db.Uuid
  brandId         String?       @map("brand_id") @db.Uuid
  collectionId    String?       @map("collection_id") @db.Uuid
  styleCode       String?       @map("style_code") @db.VarChar(100)
  title           String        @db.VarChar(500)
  description     String?
  productType     String?       @map("product_type") @db.VarChar(200)
  category        String?       @db.VarChar(200)
  material        String?       @db.VarChar(200)
  season          String?       @db.VarChar(50)
  featuredImageUrl String?      @map("featured_image_url")
  availabilityType String?      @map("availability_type") @db.VarChar(50)
  leadTimeDays    Int?          @map("lead_time_days")
  status          ProductStatus @default(DRAFT)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  brand       Brand?            @relation("ProductBrand", fields: [brandId], references: [id])
  collection  Collection?       @relation(fields: [collectionId], references: [id])
  variantGroups VariantGroup[]
  variants    ProductVariant[]
  images      ProductImage[]
  storeMaps   ShopifyProductMap[]
  issues      ProductIssue[]
  validationStates ProductValidationState[]

  @@index([brandId], name: "idx_products_brand")
  @@index([collectionId], name: "idx_products_collection")
  @@index([status], name: "idx_products_status")
  @@index([styleCode], name: "idx_products_style_code")
  @@map("products")
}

// ─── VariantGroup (INS internal grouping layer) ──────────
// Business rule: one color/material combo per product.
// sizeRun is String[] — MVP choice; future path: normalized SizeOption table.

model VariantGroup {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  color      String?  @db.VarChar(100)
  material   String?  @db.VarChar(200)
  sizeRun    String[] @map("size_run")
  imageUrl   String?  @map("image_url")
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@index([productId], name: "idx_vg_product")
  @@unique([productId, color, material], name: "uq_vg_product_color_material")
  @@map("variant_groups")
}

// ─── ProductVariant (SKU = business key) ──────────

model ProductVariant {
  id                 String        @id @default(uuid()) @db.Uuid
  productId          String        @map("product_id") @db.Uuid
  variantGroupId     String?       @map("variant_group_id") @db.Uuid
  sku                String        @unique @db.VarChar(100)
  title              String?       @db.VarChar(500)
  color              String?       @db.VarChar(100)
  size               String?       @db.VarChar(50)
  option1            String?       @db.VarChar(255)
  option2            String?       @db.VarChar(255)
  option3            String?       @db.VarChar(255)
  barcode            String?       @db.VarChar(100)
  weightGrams        Int?          @map("weight_grams")
  price              Decimal?      @db.Decimal(12,2)
  compareAtPrice     Decimal?      @map("compare_at_price") @db.Decimal(12,2)
  vendorCost         Decimal?      @map("vendor_cost") @db.Decimal(12,2)
  insDiscountType    DiscountType? @map("ins_discount_type")
  insDiscountValue   Decimal?      @map("ins_discount_value") @db.Decimal(12,2)
  estimatedMargin    Decimal?      @map("estimated_margin") @db.Decimal(5,2)
  imageUrl           String?       @map("image_url")
  status             VariantStatus @default(DRAFT)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  product               Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantGroup          VariantGroup?          @relation(fields: [variantGroupId], references: [id])
  storeMaps             ShopifyVariantMap[]
  issues                ProductIssue[]
  orderLineItems        OrderLineItem[]
  inventoryItems        InventoryItem[]
  inventoryReservations InventoryReservation[]

  @@index([productId], name: "idx_variants_product")
  @@index([variantGroupId], name: "idx_variants_vg")
  @@index([barcode], name: "idx_variants_barcode")
  @@map("product_variants")
}

// ─── ProductImage (master/shared in MVP) ──────────

model ProductImage {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  src        String
  alt        String?  @db.VarChar(500)
  position   Int      @default(0)
  width      Int?
  height     Int?
  shopifyId  BigInt?  @map("shopify_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], name: "idx_pimg_product")
  @@map("product_images")
}

// ─── ShopifyProductMap (source-specific fields) ──────────

model ShopifyProductMap {
  id                String    @id @default(uuid()) @db.Uuid
  storeId           String    @map("store_id") @db.Uuid
  productId         String    @map("product_id") @db.Uuid
  shopifyProductId  BigInt    @map("shopify_product_id")
  handle            String?   @db.VarChar(255)
  shopifyStatus     String?   @map("shopify_status") @db.VarChar(20)
  vendor            String?   @db.VarChar(255)
  tags              String[]  @default([])
  bodyHtml          String?   @map("body_html")
  shopifyCategoryId String?   @map("shopify_category_id") @db.VarChar(100)
  rawSnapshot       Json?     @map("raw_snapshot")
  lastHash          String?   @map("last_hash") @db.VarChar(64)
  syncedAt          DateTime? @map("synced_at") @db.Timestamptz()
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  store   ShopifyStore @relation(fields: [storeId], references: [id])
  product Product      @relation(fields: [productId], references: [id])

  @@unique([storeId, shopifyProductId], name: "uq_spmap_store_product")
  @@index([productId], name: "idx_spmap_product")
  @@map("shopify_product_maps")
}

// ─── ShopifyVariantMap ──────────

model ShopifyVariantMap {
  id                String    @id @default(uuid()) @db.Uuid
  storeId           String    @map("store_id") @db.Uuid
  variantId         String    @map("variant_id") @db.Uuid
  shopifyVariantId  BigInt    @map("shopify_variant_id")
  inventoryItemId   BigInt?   @map("inventory_item_id")
  shopifySku        String?   @map("shopify_sku") @db.VarChar(100)
  rawSnapshot       Json?     @map("raw_snapshot")
  syncedAt          DateTime? @map("synced_at") @db.Timestamptz()
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  store    ShopifyStore    @relation(fields: [storeId], references: [id])
  variant  ProductVariant  @relation(fields: [variantId], references: [id])

  @@unique([storeId, shopifyVariantId], name: "uq_svmap_store_variant")
  @@index([variantId], name: "idx_svmap_variant")
  @@index([shopifySku], name: "idx_svmap_sku")
  @@map("shopify_variant_maps")
}

// ─── ProductSyncJob ──────────

model ProductSyncJob {
  id          String    @id @default(uuid()) @db.Uuid
  storeId     String?   @map("store_id") @db.Uuid
  brandId     String?   @map("brand_id") @db.Uuid
  source      String    @default("shopify") @db.VarChar(20)
  status      String    @default("running") @db.VarChar(20)
  totalItems  Int       @default(0) @map("total_items")
  created     Int       @default(0)
  updated     Int       @default(0)
  skipped     Int       @default(0)
  failed      Int       @default(0)
  errorMsg    String?   @map("error_msg")
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  store ShopifyStore? @relation("ProductSyncStore", fields: [storeId], references: [id])
  brand Brand?        @relation("IntakeBrand", fields: [brandId], references: [id])
  logs  ProductSyncLog[]

  @@index([storeId], name: "idx_psj_store")
  @@index([brandId], name: "idx_psj_brand")
  @@map("product_sync_jobs")
}

// ─── ProductSyncLog ──────────

model ProductSyncLog {
  id        String     @id @default(uuid()) @db.Uuid
  jobId     String     @map("job_id") @db.Uuid
  action    SyncAction
  level     String     @default("info") @db.VarChar(10)
  message   String
  data      Json?
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  job ProductSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId], name: "idx_psl_job")
  @@map("product_sync_logs")
}

// ─── ProductIssue ──────────

model ProductIssue {
  id         String        @id @default(uuid()) @db.Uuid
  productId  String?       @map("product_id") @db.Uuid
  variantId  String?       @map("variant_id") @db.Uuid
  ruleCode   String        @map("rule_code") @db.VarChar(50)
  severity   IssueSeverity @default(WARNING)
  status     IssueStatus   @default(OPEN)
  message    String
  resolvedBy String?       @map("resolved_by") @db.Uuid
  resolvedAt DateTime?     @map("resolved_at") @db.Timestamptz()
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  product Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId], name: "idx_pi_product")
  @@index([variantId], name: "idx_pi_variant")
  @@index([status], name: "idx_pi_status")
  @@index([ruleCode], name: "idx_pi_rule")
  @@map("product_issues")
}


// ═══════════════════════════════════════
// Sprint 1 — Job Queue (DB-based)
// ═══════════════════════════════════════

model SyncJob {
  id          String    @id @default(uuid()) @db.Uuid
  storeId     String?   @map("store_id") @db.Uuid
  jobType     String    @map("job_type") @db.VarChar(50)
  status      String    @default("pending") @db.VarChar(20)
  totalItems  Int       @default(0) @map("total_items")
  processed   Int       @default(0)
  failed      Int       @default(0)
  errorMsg    String?   @map("error_msg")
  metadata    Json?     @default("{}")
  startedAt   DateTime? @map("started_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  store ShopifyStore? @relation(fields: [storeId], references: [id])
  logs  SyncJobLog[]

  @@index([status], name: "idx_syncjob_status")
  @@index([storeId], name: "idx_syncjob_store")
  @@map("sync_jobs")
}

model SyncJobLog {
  id                 String   @id @default(uuid()) @db.Uuid
  jobId              String   @map("job_id") @db.Uuid
  level              String   @default("info") @db.VarChar(10)
  message            String
  data               Json?
  // Sprint 2: metafield push tracking
  metafieldValueId   String?  @map("metafield_value_id") @db.Uuid
  storeId            String?  @map("store_id") @db.Uuid
  shopifyResourceId  String?  @map("shopify_resource_id") @db.VarChar(50)
  shopifyMetafieldId String?  @map("shopify_metafield_id") @db.VarChar(50)
  payload            Json?
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()

  job SyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId], name: "idx_syncjoblog_job")
  @@index([metafieldValueId], name: "idx_syncjoblog_mfv")
  @@map("sync_job_logs")
}

model Order {
  id                 String    @id @default(uuid()) @db.Uuid
  shopifyStoreId     String    @map("shopify_store_id") @db.Uuid
  shopifyOrderId     BigInt    @map("shopify_order_id")
  orderNumber        String    @map("order_number") @db.VarChar(50)
  status             String    @default("open") @db.VarChar(20)
  financialStatus    String?   @map("financial_status") @db.VarChar(30)
  fulfillmentStatus  String?   @map("fulfillment_status") @db.VarChar(30)
  // — Phase 1: customer & address —
  customerEmail      String?   @map("customer_email") @db.VarChar(255)
  customerName       String?   @map("customer_name") @db.VarChar(255)
  customerPhone      String?   @map("customer_phone") @db.VarChar(50)
  shippingAddress    Json?     @map("shipping_address")
  shippingCountry    String?   @map("shipping_country") @db.VarChar(10)
  shippingCity       String?   @map("shipping_city") @db.VarChar(100)
  // — Phase 1: pipeline state machine —
  pipelineState      String    @default("NEW_FROM_SHOPIFY") @map("pipeline_state") @db.VarChar(40)
  flags              Json?     @default("{}")
  notes              String?
  // — Phase 1: fulfillment tracking —
  trackingNumber     String?   @map("tracking_number") @db.VarChar(255)
  trackingCompany    String?   @map("tracking_company") @db.VarChar(100)
  trackingUrl        String?   @map("tracking_url")
  shopifyRawPayload  Json?     @map("shopify_raw_payload")
  // — Financial details (from Lark) —
  totalPrice             Decimal   @map("total_price") @db.Decimal(10, 2)
  totalLineItemsPrice    Decimal?  @map("total_line_items_price") @db.Decimal(10, 2)
  totalShippingPrice     Decimal?  @map("total_shipping_price") @db.Decimal(10, 2)
  totalDiscounts         Decimal?  @map("total_discounts") @db.Decimal(10, 2)
  totalTip               Decimal?  @map("total_tip") @db.Decimal(10, 2)
  totalWeight            Decimal?  @map("total_weight") @db.Decimal(10, 2)
  totalQuantity          Int?      @map("total_quantity")
  currency               String    @db.VarChar(3)
  // — Billing address —
  billingAddress         Json?     @map("billing_address")
  // — Discount details —
  discountCodes          String?   @map("discount_codes")
  discountValue          Decimal?  @map("discount_value") @db.Decimal(10, 2)
  discountValueType      String?   @map("discount_value_type") @db.VarChar(30)
  discountTargetType     String?   @map("discount_target_type") @db.VarChar(30)
  discountDescription    String?   @map("discount_description")
  discountTitle          String?   @map("discount_title") @db.VarChar(100)
  // — Shipping method —
  shippingMethodCode     String?   @map("shipping_method_code") @db.VarChar(50)
  shippingMethodSource   String?   @map("shipping_method_source") @db.VarChar(100)
  // — Payment & shipment —
  paymentGateway         String?   @map("payment_gateway") @db.VarChar(100)
  shipmentStatus         String?   @map("shipment_status") @db.VarChar(30)
  // — common —
  orderDate              DateTime  @map("order_date") @db.Timestamptz()
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  shopifyStore ShopifyStore    @relation(fields: [shopifyStoreId], references: [id])
  lineItems    OrderLineItem[]
  tasks        Task[]
  orderLogs    OrderLog[]

  @@unique([shopifyStoreId, shopifyOrderId], name: "uq_order_store_shopify")
  @@index([status], name: "idx_orders_status")
  @@index([pipelineState], name: "idx_orders_pipeline_state")
  @@index([orderDate], name: "idx_orders_date")
  @@map("orders")
}

model OrderLineItem {
  id                  String   @id @default(uuid()) @db.Uuid
  orderId             String   @map("order_id") @db.Uuid
  variantId           String?  @map("variant_id") @db.Uuid
  brandId             String?  @map("brand_id") @db.Uuid
  shopifyLineItemId   BigInt   @map("shopify_line_item_id")
  shopifyVariantId    BigInt?  @map("shopify_variant_id")
  title               String   @db.VarChar(255)
  sku                 String?  @db.VarChar(100)
  quantity            Int
  unitPrice           Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice          Decimal  @map("total_price") @db.Decimal(10, 2)
  mappingStatus       String   @default("UNMAPPED") @map("mapping_status") @db.VarChar(20)
  itemState           String   @default("PENDING") @map("item_state") @db.VarChar(30)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  order                  Order                  @relation(fields: [orderId], references: [id])
  variant                ProductVariant?        @relation(fields: [variantId], references: [id])
  brand                  Brand?                 @relation(fields: [brandId], references: [id])
  inventoryReservations  InventoryReservation[]
  procurementRequests    ProcurementRequest[]

  @@unique([orderId, shopifyLineItemId], name: "uq_oli_order_shopify")
  @@index([orderId], name: "idx_oli_order")
  @@index([variantId], name: "idx_oli_variant")
  @@index([brandId], name: "idx_oli_brand")
  @@index([itemState], name: "idx_oli_item_state")
  @@map("order_line_items")
}

// ═══════════════════════════════════════
// Phase 1 — Order Pipeline: Tasks, Reservations, Procurement
// ═══════════════════════════════════════

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  type        String    @db.VarChar(30)
  orderId     String    @map("order_id") @db.Uuid
  assigneeId  String?   @map("assignee_id") @db.Uuid
  status      String    @default("OPEN") @db.VarChar(20)
  priority    String    @default("NORMAL") @db.VarChar(20)
  dueAt       DateTime? @map("due_at") @db.Timestamptz()
  completedAt DateTime? @map("completed_at") @db.Timestamptz()
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  order    Order  @relation(fields: [orderId], references: [id])
  assignee User?  @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments TaskComment[]

  @@index([orderId], name: "idx_tasks_order")
  @@index([type], name: "idx_tasks_type")
  @@index([status], name: "idx_tasks_status")
  @@index([assigneeId], name: "idx_tasks_assignee")
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  task Task @relation(fields: [taskId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([taskId], name: "idx_tc_task")
  @@map("task_comments")
}

model InventoryReservation {
  id          String    @id @default(uuid()) @db.Uuid
  orderItemId String    @map("order_item_id") @db.Uuid
  variantId   String?   @map("variant_id") @db.Uuid
  sku         String    @db.VarChar(100)
  warehouseId String    @map("warehouse_id") @db.Uuid
  qtyReserved Int       @map("qty_reserved")
  status      String    @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  orderItem OrderLineItem @relation(fields: [orderItemId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])

  @@index([orderItemId], name: "idx_ir_order_item")
  @@index([warehouseId], name: "idx_ir_warehouse")
