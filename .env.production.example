# ──────────────────────────────────────
# INS Commerce Hub — Production Environment Variables
# Copy to .env.production and fill in real values
# ──────────────────────────────────────

# ── Database (Supabase) ──
# Get from: Supabase → Project → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.xxx:password@db.xxx.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:password@db.xxx.supabase.co:5432/postgres

# ── Redis (Upstash) ──
# Get from: Upstash Console → Redis → Details
REDIS_HOST=xxx.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=AXxx...
REDIS_TLS=true

# ── Auth ──
# GENERATE STRONG SECRETS: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_EXPIRY=24h

# ── Encryption (AES-256) ──
# GENERATE: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX

# ── Shopify ──
SHOPIFY_SCOPES=read_products,read_orders,read_inventory,read_locations
SHOPIFY_API_VERSION=2025-01

# ── CORS ──
CORS_ORIGIN=https://hub.inecso.com

# ── Server ──
API_PORT=3001
NODE_ENV=production
LOG_LEVEL=info
