# ──────────────────────────────────────
# INS Commerce Hub — Environment Variables
# Copy to .env and fill in values
# ──────────────────────────────────────

# Database
DATABASE_URL=postgresql://ins:ins_dev_password@localhost:5433/ins_commerce_hub

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# Auth
JWT_SECRET=change-me-to-a-256-bit-secret-in-production
JWT_EXPIRY=24h

# Encryption (64 hex chars = 256 bits for AES-256-GCM)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Shopify
SHOPIFY_API_VERSION=2025-01

# Server
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=debug
